{
  "manifest_version": 3,
  "name": "Akprays - Akakçe Fiyat Takibi",
  "version": "3.6",
  "description": "Akakçe ürün fiyatlarını takip edin, fiyat geçmişini görün ve indirimleri bildirim olarak alın.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.akakce.com/*",
    "https://akakce.com/*",
    "https://*.itopya.com/*",
    "https://*.incehesap.com/*",
    "https://incehesap.ggbaba.info/*",
    "https://*.pttavm.com/*",
    "https://*.n11.com/*",
    "https://*.vatanbilgisayar.com/*",
    "https://api.callmebot.com/*",
    "https://discord.com/api/webhooks/*",
    "https://exifsxceyfjpijansmlb.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.akakce.com/*",
        "*://*.itopya.com/*",
        "*://*.incehesap.com/*",
        "*://*.pttavm.com/*",
        "*://*.n11.com/*",
        "*://*.vatanbilgisayar.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "akprays@emirhankiziloglu.com",
      "strict_min_version": "121.0"
    }
  }
}